# Database configuration - PostgreSQL + asyncpg
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.ref.supabase.co:5432/postgres?sslmode=require

# JWT Configuration
# Generate a strong key in production (e.g., openssl rand -hex 32)
JWT_SECRET_KEY=your_super_secret_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Origins (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000
